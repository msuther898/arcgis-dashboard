VITE_ARCGIS_USERNAME=your_username
VITE_ARCGIS_PASSWORD=your_password
VITE_ARCGIS_ORG_URL=https://geocam.maps.arcgis.com

# MinIO Configuration (optional - enables direct archive uploads)
VITE_MINIO_ENDPOINT=http://localhost:9000
VITE_MINIO_BUCKET=arcgis-archive
VITE_MINIO_ACCESS_KEY=your_minio_access_key
VITE_MINIO_SECRET_KEY=your_minio_secret_key
